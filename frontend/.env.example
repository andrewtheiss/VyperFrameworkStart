# WalletConnect Cloud project ID — https://cloud.walletconnect.com
# Required for mobile-wallet QR connections via RainbowKit.
# Without it the app still works with injected wallets (MetaMask etc.).
VITE_WC_PROJECT_ID=

# Sepolia RPC URL (default network for this app).
# Recommended: Alchemy or Infura — public RPCs are heavily rate-limited and
# may cause "missing response for request" errors under load.
# Examples:
#   https://eth-sepolia.g.alchemy.com/v2/<KEY>
#   https://sepolia.infura.io/v3/<KEY>
VITE_SEPOLIA_RPC_URL=

# Mainnet RPC URL — only needed if you plan to interact with mainnet.
VITE_MAINNET_RPC_URL=
